# Application
APP_NAME="RAG System API"
APP_VERSION="0.1.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./rag_system.db

# Vector Database
VECTOR_DB_TYPE=pgvector
# Note: pgvector requires PostgreSQL. Uses same DATABASE_URL as main app.

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.9
LLM_SYSTEM_PROMPT="You are a helpful AI assistant. Answer questions based on the provided context."

# Embedding Configuration
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIMENSIONS=768

# Embedding Optimization (CPU-optimized batch processing)
EMBEDDING_BATCH_SIZE=16
EMBEDDING_CONCURRENCY=4
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_DELAY=1.0
EMBEDDING_CPU_OPTIMIZED=true

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=semantic
BATCH_SIZE=32

# Retrieval Configuration
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# API Keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# Supported formats: PDF, DOCX, TXT, MD, HTML, CSV, JSON (custom loaders)
# Plus EPUB, PPTX, ODT, RTF, XML (via LangChain fallback)
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md,.html,.csv,.json,.epub,.pptx,.odt,.rtf,.xml
